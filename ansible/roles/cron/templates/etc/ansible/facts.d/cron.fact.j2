from __future__ import print_function
from json import dumps, loads
from sys import exit
import os


def cmd_exists(cmd):
    if os.path.isabs(cmd):
        return os.access(cmd, os.X_OK)
    else:
        return any(
            os.access(os.path.join(path, cmd), os.X_OK)
            for path in os.environ["PATH"].split(os.pathsep)
        )


output = {'enabled': True}
output['daemon'] = '{{ cron__daemon | d("unknown") }}'

{% if cron__daemon | d() == "cron" %}
output['installed'] = cmd_exists('cron')
{% elif cron__daemon | d() == "systemd-cron" %}
output['installed'] = cmd_exists('/lib/systemd/system-generators/systemd-crontab-generator')
{% else %}
output['installed'] = False
{% endif %}

output['crontab_offset_seeds'] = loads('''{{ cron__crontab_offset_seeds
                                             | to_nice_json }}''')

print(dumps(output, sort_keys=True, indent=4))
