{% macro parse_options_to_json(opts) %}
{%   set subopts = dict() %}
{%   for option in opts | d([]) %}
{%     if option.state | d("present") == "present" %}
{%       if option.option | d(option.name) %}
{%         set name = option.option | d(option.name) %}
{%         if option.options | d() %}
{%           set value = parse_options_to_json(option.options) | from_json %}
{%         elif option.value is not defined %}
{%           set value = "INVALID" %}
{%         elif option.value is string and option.value == "0" %}
{%           set value = 0 %}
{%         elif option.value is string and option.value | int != 0 %}
{%           set value = option.value | int %}
{%         elif option.value is string %}
{%           set value = option.value %}
{%         elif option.value is sameas true %}
{%           set value = option.value %}
{%         elif option.value is sameas false %}
{%           set value = option.value %}
{%         elif option.value is number %}
{%           set value = option.value %}
{%         elif option.value is iterable and option.value is not mapping %}
{%           set value = [] %}
{%           for x in option.value %}
{%             if x.state | d('present') != 'absent' %}
{{-              value.append(x.name) -}}
{%             endif %}
{%           endfor %}
{%         else %}
{%           set value = "INVALID" %}
{%         endif %}
{{-        subopts.update({ name: value }) -}}
{%       endif %}
{%     endif %}
{%   endfor %}
{{-  subopts | to_json -}}
{% endmacro %}
